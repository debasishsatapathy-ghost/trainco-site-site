# Local Development Configuration
# Copy this file to .env.local and fill in your values.
# Get your dev API key from: Dashboard > Websites > [Your Site] > Local Development

# Mobeus Widget Configuration (Required)
NEXT_PUBLIC_WIDGET_API_KEY=vk_dev_your_key_here
NEXT_PUBLIC_WIDGET_HOST=https://app.mobeus.ai

# Agent Configuration
NEXT_PUBLIC_AGENT_NAME=TrainCo Assistant

# Optional: Dev Toolbar (localhost only)
NEXT_PUBLIC_DEV_TOOLBAR_HOST=localhost
